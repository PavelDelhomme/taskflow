# =============================================================================
# TaskFlow — variables stack Portainer (MODÈLE — pas de vrais secrets)
# Copier dans Portainer → Stack → Environment variables (advanced)
# Générer des valeurs : make secrets-print
# =============================================================================

# --- Base de données ---
POSTGRES_DB=taskflow_adhd
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=REMPLACER_openssl_rand_hex_24

# --- Sécurité API ---
SECRET_KEY=REMPLACER_openssl_rand_hex_32

# --- Environnement runtime ---
NODE_ENV=production
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# --- URLs publiques PROD (delhomme.ovh + NPM) ---
NEXT_PUBLIC_API_URL=https://api.taskflow.delhomme.ovh
CORS_ORIGINS=https://taskflow.delhomme.ovh,https://api.taskflow.delhomme.ovh

# --- Inscription (prod : false) ---
ALLOW_REGISTRATION=false
NEXT_PUBLIC_ALLOW_REGISTRATION=false

# --- Comptes (hash dans seed-users.sql — exécuter après 1er deploy) ---
# OWNER : Pactivisme / paveldelhomme@gmail.com
# DEMO  : demo@taskflow.local / DemoTaskFlow2025!

# --- Réseau Docker (comme nextcloud-stack, n8n-stack) ---
# La stack utilise shared-network-copy (external) — NPM accède via :
#   Web : http://taskflow:3000
#   API : http://taskflow-api:8000

# --- Build Portainer ---
IMAGE_PULL_POLICY=build

# --- PRÉPROD (stack taskflow-stack-preprod) — décommenter et adapter ---
# NEXT_PUBLIC_API_URL=https://api-staging.taskflow.delhomme.ovh
# CORS_ORIGINS=https://staging.taskflow.delhomme.ovh,https://api-staging.taskflow.delhomme.ovh
# WEB_PUBLISH_PORT=4010
# API_PUBLISH_PORT=4011
# DB_PUBLISH_PORT=4012
# IMAGE_TAG=dev

# --- Mobile (build Flutter / CI — pas utilisé par la stack Docker web) ---
# MOBILE_API_URL=https://api.taskflow.delhomme.ovh

# --- Intégrations futures (Google Tasks, Cloudity, tasks.delhomme.ovh) ---
# GOOGLE_TASKS_CLIENT_ID=
# GOOGLE_TASKS_CLIENT_SECRET=
# GOOGLE_TASKS_REDIRECT_URI=https://api.taskflow.delhomme.ovh/auth/google/callback
# CLOUDITY_API_URL=https://api.cloudity.delhomme.ovh
# TASKS_LEGACY_URL=https://tasks.delhomme.ovh
