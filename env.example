# =============================================================================
# TaskFlow — modèle de configuration (copier vers .env : make init)
# Secrets réels : .env uniquement (gitignored) ou Portainer (stack.env.example)
# =============================================================================

# --- Base de données (dev Docker) ---
DATABASE_URL=postgresql://taskflow:taskflow123@localhost:4002/taskflow_adhd
POSTGRES_DB=taskflow_adhd
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow123

# --- Sécurité JWT ---
SECRET_KEY=change-me-jwt-secret-local

# --- API & Web (dev) ---
API_URL=http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4001
CORS_ORIGINS=http://localhost:4000,http://taskflow-web:3000

# --- Environnement ---
NODE_ENV=development
PYTHONUNBUFFERED=1
PYTHONPATH=/app
LOG_LEVEL=INFO
LOG_FILE=logs/taskflow.log

# --- Inscription publique ---
# false en prod : seul le propriétaire décide qui peut s'inscrire (make seed-users)
ALLOW_REGISTRATION=false
NEXT_PUBLIC_ALLOW_REGISTRATION=false

# --- Compte propriétaire (Paul Delhomme) ---
# Mot de passe réel dans .env seulement — jamais committer
OWNER_USERNAME=Pactivisme
OWNER_FULL_NAME="Paul Delhomme"
OWNER_EMAIL=paveldelhomme@gmail.com
OWNER_PASSWORD=REMPLACER_votre_mot_de_passe_proprietaire

# --- Compte démo (make secrets-print-accounts pour générer DEMO_PASSWORD) ---
DEMO_USERNAME=demo
DEMO_FULL_NAME="Compte Démo TaskFlow"
DEMO_EMAIL=demo@taskflow.local
DEMO_PASSWORD=REMPLACER_make_secrets_print_accounts

# Ports dev : Web 4000 · API 4001 · DB 4002

# --- Production (make up-prod / Portainer) ---
# NEXT_PUBLIC_API_URL=https://api.taskflow.delhomme.ovh
# CORS_ORIGINS=https://taskflow.delhomme.ovh,https://api.taskflow.delhomme.ovh
# POSTGRES_PASSWORD=REMPLACER_openssl_rand_hex_24
# SECRET_KEY=REMPLACER_openssl_rand_hex_32
# ALLOW_REGISTRATION=false
# WEB_PUBLISH_PORT=4000
# API_PUBLISH_PORT=4001
# DB_PUBLISH_PORT=4002
# IMAGE_REGISTRY=ghcr.io/paveldelhomme
# IMAGE_TAG=latest

# --- Intégrations futures ---
# GOOGLE_TASKS_CLIENT_ID=
# CLOUDITY_API_URL=
# TASKS_LEGACY_URL=https://tasks.delhomme.ovh

# Voir docs/UTILISATEURS.md pour connexion et déploiement des comptes.
